<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ledge.ui.Sidebar"
      spacing="10" prefWidth="200.0" style="-fx-border-color: #cccccc; -fx-border-width: 0 1 0 0;">
    <padding>
        <Insets top="20" right="10" bottom="20" left="10"/>
    </padding>
    <Button fx:id="dashboardBtn" text="Inventory Dashboard" onAction="#showInventoryDashboard" maxWidth="Infinity" />
    <Button fx:id="addProductBtn" text="Add Product" onAction="#showAddProduct" maxWidth="Infinity" />
    <VBox VBox.vgrow="ALWAYS" />
    <Button text="Logout" onAction="#handleLogout" maxWidth="Infinity" style="-fx-text-fill: red;" />
</VBox>
