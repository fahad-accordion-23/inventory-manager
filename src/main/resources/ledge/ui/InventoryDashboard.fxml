<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ledge.ui.InventoryDashboard"
      spacing="15" VBox.vgrow="ALWAYS">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Current Inventory" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Refresh" onAction="#handleRefreshAction" />
    </HBox>

    <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Product Name" prefWidth="200">
                <cellValueFactory>
                    <PropertyValueFactory property="name" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn text="Purchase Price" prefWidth="120">
                <cellValueFactory>
                    <PropertyValueFactory property="purchasePrice" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn text="Selling Price" prefWidth="120">
                <cellValueFactory>
                    <PropertyValueFactory property="sellingPrice" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn text="In Stock" prefWidth="100">
                <cellValueFactory>
                    <PropertyValueFactory property="stockQuantity" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn text="Tax Rate" prefWidth="100">
                <cellValueFactory>
                    <PropertyValueFactory property="taxRate" />
                </cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>

</VBox>
