<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ledge.ui.pages.AddRoleView">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Create/Edit Role" />

    <VBox spacing="5.0">
        <Label style="-fx-font-weight: bold;" text="Role Name" />
        <TextField fx:id="roleNameField" prefWidth="300.0" promptText="e.g. Inventory Manager" />
    </VBox>

    <VBox spacing="10.0" VBox.vgrow="ALWAYS">
        <Label style="-fx-font-weight: bold;" text="Permissions Matrix" />
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <GridPane fx:id="permissionMatrix" hgap="15.0" vgap="10.0" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
                <!-- Content generated in controller -->
            </GridPane>
        </ScrollPane>
    </VBox>

    <HBox spacing="15.0">
        <Button onAction="#handleSave" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="Save Role" />
        <Button onAction="#handleCancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" text="Cancel" />
    </HBox>
</VBox>
