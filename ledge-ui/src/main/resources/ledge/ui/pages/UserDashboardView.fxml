<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ledge.ui.pages.UserDashboardView"
      spacing="15" VBox.vgrow="ALWAYS">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="User Accounts" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="addUserBtn" text="Add New User" onAction="#handleAddUser" 
                style="-fx-background-color: #0984e3; -fx-text-fill: white;"/>
        <Button text="Refresh" onAction="#handleRefresh" />
    </HBox>

    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Username" prefWidth="250">
                <cellValueFactory>
                    <PropertyValueFactory property="username" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn text="Role" prefWidth="150">
                <cellValueFactory>
                    <PropertyValueFactory property="roleName" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="200" />
        </columns>
    </TableView>

</VBox>
